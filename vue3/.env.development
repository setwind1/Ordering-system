# 开发环境：本地启动前端，通过 Vite Proxy 请求本地后端
VITE_DEV=true

# 请求路径（空字符串，使请求发到 Vite 开发服务器同源）
VITE_BASE_URL=''

# 接口路径前缀
VITE_API_URL=/admin-api

# 文件上传类型：server - 后端上传
VITE_UPLOAD_TYPE=server
VITE_UPLOAD_URL=/admin-api/infra/file/upload

# 是否删除debugger
VITE_DROP_DEBUGGER=false

# 是否删除console.log
VITE_DROP_CONSOLE=false

# 是否sourcemap
VITE_SOURCEMAP=true

# 打包路径
VITE_BASE_PATH=/

# 输出路径
VITE_OUT_DIR=dist

# 验证码的开关
VITE_APP_CAPTCHA_ENABLE=true
